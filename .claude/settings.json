{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-plugin-versions.sh --mode stop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'case \"$CLAUDE_TOOL_INPUT\" in *\"gh pr create\"*) bash .claude/scripts/check-plugin-versions.sh --mode pr ;; esac'"
          }
        ]
      }
    ]
  }
}
